{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://b3-bmf-derivatives-production.up.railway.app/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://b3-bmf-derivatives-production.up.railway.app/ws/:path*"
    }
  ]
}
